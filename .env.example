# Canonical origin for sitemap, canonical URLs, and Open Graph resolution.
# Set this in Vercel (Production + Preview if desired): Project → Settings → Environment Variables
NEXT_PUBLIC_SITE_URL=https://www.reviewaware.com

# Optional — override app signup URLs (see VERCEL_DEPLOYMENT.md and docs/plus-signup-mismatch.md).
# Plus CTAs always include plan=plus in code; unset = defaults to app.reviewaware.com/signup + plan=plus.
# NEXT_PUBLIC_LITE_TRIAL_URL=https://app.reviewaware.com/signup
# NEXT_PUBLIC_LITE_TRIAL_URL_ES=https://app.reviewaware.com/signup?lang=es
# NEXT_PUBLIC_PLUS_SIGNUP_URL=https://app.reviewaware.com/signup?plan=plus
# NEXT_PUBLIC_PLUS_SIGNUP_URL_ES=https://app.reviewaware.com/signup?plan=plus&lang=es
